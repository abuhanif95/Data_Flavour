API_PORT=8000

# Ubuntu / HDFS settings
HDFS_NAMENODE_URL=http://192.168.56.105:9870
HDFS_USER=hanif
HDFS_BASE_PATH=/user/hanif/yelp
HDFS_DATASETS=business,user,checkin,review,tip
HDFS_MAX_FILES_PER_DATASET=40
HDFS_OPEN_LENGTH_BYTES=4194304
HDFS_TIMEOUT_SECONDS=12
HDFS_REMOTE_MAX_LINES=100000
HDFS_ENRICHMENT_BASE_PATHS=/user/hanif/yelp,/user/hanif/yelp_external
ENRICHMENT_MAX_ROWS_PER_SOURCE=1200

# SSH fallback (for blocked DataNode redirects)
UBUNTU_SSH_ENABLED=true
UBUNTU_HOST=192.168.56.105
UBUNTU_PORT=22
UBUNTU_USERNAME=hanif
UBUNTU_PASSWORD=1234
UBUNTU_ZIP_PATH=/home/hanif/Yelp-JSON.zip
UBUNTU_ZIP_MAX_ROWS=5000

STARTUP_SYNC=false

# Local cache and response tuning
LOCAL_DATA_DIR=./data/raw
CHAT_MAX_ROWS=80
CHAT_MAX_ROW_VALUE_CHARS=220
CHAT_MAX_ROW_COLUMNS=16
CHART_MAX_POINTS=40

# Optional LLM for higher quality natural-language answers
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
